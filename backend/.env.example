# Copy to .env and fill in. Never commit the real .env.

# --- Django ---
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=

# --- Production hardening (DJANGO_DEBUG=False) ---
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_HSTS_SECONDS=2592000
DJANGO_DB_CONN_MAX_AGE=60

# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL=postgres://prepcheck:prepcheck@postgres:5432/prepcheck

# --- Redis / Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MIN=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- LLM + embedding providers ---
LLM_PROVIDER=fake            # fake | anthropic | gemini
EMBEDDING_PROVIDER=fake      # fake | voyage

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-5

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Embeddings (Voyage) ---
VOYAGE_API_KEY=
ANTHROPIC_EMBEDDING_MODEL=voyage-3
EMBEDDING_DIM=1024

# --- Per-tenant LLM rate limiting ---
LLM_DAILY_CALL_CAP_PER_TENANT=500
LLM_MONTHLY_CALL_CAP_PER_TENANT=10000

# --- Tenant isolation ---
TENANT_STRICT=True
